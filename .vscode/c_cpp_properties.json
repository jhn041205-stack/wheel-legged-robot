{
  "configurations": [
    {
      "name": "windows-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_DEBUG",
        "UNICODE",
        "_UNICODE",
        "USE_HAL_DRIVER",
        "STM32F407xx",
        "USE_HAL_DRIVER",
        "STM32F407xx",
        "ARM_MATH_CM4",
        "__FPU_USED=1U",
        "__FPU_PRESENT=1U",
        "ARM_MATH_MATRIX_CHECK",
        "ARM_MATH_ROUNDING"
      ],
      "cStandard": "${default}",
      "cppStandard": "${default}",
      "intelliSenseMode": "windows-gcc-x64",
      "compilerPath": "gcc"
    }
  ],
  "version": 4
}